
    
    <% layout("/layouts/boilerplate") -%>

         <div class="col-8 offset-2">
    <form method="POST" action="/listing">
      <br>

      <h5>Create a new Listing</h5>
     <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input name="Listing[title]" placeholder="enter title" class="form-control">
     </div>
     <div class="mb-3">
        <label for="descritpion" class="form-label">Description</label>
        <textarea  name="Listing[description]" class="form-control" ></textarea>  
     </div>
    <div class="mb-3">
        <label for="price" class="form-label">Price</label>
        <input name="Listing[price]" placeholder="enter price" class="form-control">
    </div>
   <div class="mb-3">
        <label for="image" class="form-label">Image Link</label>
        <input name="Listing[image]" placeholder="enter image url/link" class="form-control"> 
   </div>
    <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <input name="Listing[location]" placeholder="enter location" class="form-control"> 
    </div>
    <div class="mb-3">
        <label for="country" class="form-label">Country</label>
        <input name="Listing[country]" placeholder="enter country" class="form-control">
    </div>
    
   <br>
   <button class="btn btn-dark add-btn">Add</button>
   </form>
   </div>
      

    
